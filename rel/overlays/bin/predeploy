#!/bin/sh
set -eu

cd -P -- "$(dirname -- "$0")"

# Schema changes must succeed before a new release can start.
./migrate

# TfL and OSM are third-party services. Refresh the map on every deployment,
# but keep serving the last successful import when either service is
# temporarily unavailable.
if ! ./transitmaps eval 'Transitmaps.Release.import_tfl()'; then
  echo "WARNING: TfL refresh failed; deploying with the existing map data." >&2
fi
